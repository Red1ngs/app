# ── telegram-service ───────────────────────────────────────────────────────
# Адмінський Telegram-бот — окремий контейнер, ці дві змінні йому і
# підставляються в docker-compose.yml (в core-service вони більше не
# потрібні).
ADMIN_BOT_TOKEN=
ADMIN_IDS=123456789

# ── account-service ────────────────────────────────────────────────────────
# Токен для account-service HTTP API (core-service/rpc/server.py у сесіях
# акаунтів). Порожньо — довіряємо внутрішній docker-мережі (дефолт, ОК для
# приватної мережі; задай значення, якщо порт 8100 колись буде проброшений
# назовні).
ACCOUNT_SERVICE_TOKEN=

# ── core-service ───────────────────────────────────────────────────────────
# Токен для generic RPC (core-service/src/core/rpc/server.py) — той самий,
# що вживає telegram-service для звернень до core-service. Порожньо —
# довіряємо внутрішній docker-мережі (дефолт, ОК для приватної мережі;
# задай значення, якщо RPC-порт 8200 колись буде проброшений назовні).
CORE_SERVICE_TOKEN=

# ── Інфраструктура (докидається автоматично docker-compose, тут для довідки) ──
# ACCOUNT_SERVICE_URL=http://account-service:8100
# CORE_SERVICE_URL=http://core-service:8200
# REDIS_URL=redis://redis:6379/0
