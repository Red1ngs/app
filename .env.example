# ── telegram-service ───────────────────────────────────────────────────────
# Адмінський Telegram-бот — окремий контейнер, ці дві змінні йому і
# підставляються в docker-compose.yml (в core-service вони більше не
# потрібні).
ADMIN_BOT_TOKEN=
ADMIN_IDS=123456789

# ── core-service (колишній "app") ─────────────────────────────────────────
# Паролі акаунтів — той самий механізм, що й раніше (SchedulerService._load_credentials):
# ACCOUNT_PASSWORD_<slug_id>=...
# ACCOUNT_PROXY_<slug_id>=...   (опційно)

# Токен для generic RPC (src/core/rpc/server.py) — той самий, що вживає
# telegram-service для звернень до core-service. Порожньо — довіряємо
# внутрішній docker-мережі (дефолт, ОК для приватної мережі; задай
# значення, якщо RPC-порт колись буде проброшений назовні).
CORE_SERVICE_TOKEN=

# ── Інфраструктура (докидається автоматично docker-compose, тут для довідки) ──
# ACCOUNT_SERVICE_URL=http://account-service:8100
# CORE_SERVICE_URL=http://core-service:8200
# REDIS_URL=redis://redis:6379/0

# ── card-evaluation (спільний сервіс; читається docker-compose.yml і
# підставляється в обидва сервіси, що ним користуються — card-evaluation
# сам і trade-helper-api, — щоб токен був один і той самий для обох) ──────
CE_CATALOG_UPDATE_HOURS=6
CE_MB_ACCOUNT_ID=
CARD_EVALUATION_SERVICE_TOKEN=

# ── trade-helper (TG_BOT_TOKEN для trade-helper-telegram живе в
# ../trade-helper/.env, не тут — див. ../trade-helper/.env.example) ──────
