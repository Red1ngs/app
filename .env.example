# ── Бізнес-застосунок (app) ───────────────────────────────────────────────────
# Admin Telegram bot
ADMIN_BOT_TOKEN=
ADMIN_IDS=123456789

# Паролі акаунтів — той самий механізм, що й раніше (SchedulerService._load_credentials):
# ACCOUNT_PASSWORD_<slug_id>=...
# ACCOUNT_PROXY_<slug_id>=...   (опційно)

# ── Інфраструктура (докидається автоматично docker-compose, тут для довідки) ──
# ACCOUNT_SERVICE_URL=http://account-service:8100
# REDIS_URL=redis://redis:6379/0

# ── card-evaluation (спільний сервіс; читається docker-compose.yml і
# підставляється в обидва сервіси, що ним користуються — card-evaluation
# сам і trade-helper-api, — щоб токен був один і той самий для обох) ──────
CE_CATALOG_UPDATE_HOURS=6
CE_MB_ACCOUNT_ID=
CARD_EVALUATION_SERVICE_TOKEN=

